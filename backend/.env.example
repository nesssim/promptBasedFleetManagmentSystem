# LLM provider priority: ANTHROPIC_API_KEY > GOOGLE_API_KEY > LOCAL_LLM_URL
# Leave all empty for mock mode (planning/generation returns null results)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local LLM via OpenAI-compatible API (LM Studio, Ollama, etc.)
# Default port for LM Studio is 1234, for Ollama it's 11434
LOCAL_LLM_URL=
LOCAL_LLM_MODEL=

# Optional: Gemini model override (default: gemini-flash-latest)
# Set only if the default doesn't work with your API key
GOOGLE_GEMINI_MODEL=

# Optional: API key for endpoint authentication
# Set to enable auth on /launch and /kill endpoints
API_KEY=

# Optional: CORS allowed origin (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Set to any value to enable OpenAPI docs at /docs
MISSION_DEBUG=true
