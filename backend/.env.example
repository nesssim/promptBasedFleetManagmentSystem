# Anthropic API key for LLM integration
# Leave empty for mock mode (planning/generation returns null results)
ANTHROPIC_API_KEY=

# Optional: API key for endpoint authentication
# Set to enable auth on /launch and /kill endpoints
API_KEY=

# Optional: CORS allowed origin (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Set to any value to enable OpenAPI docs at /docs
MISSION_DEBUG=true
